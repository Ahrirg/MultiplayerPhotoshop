# Authority server port. Frontend currently expects Authority on port 8000.
SERVICE_PORT=8000

# Back_end_database must be running here. Recommended command from Back_end_database folder:
# uv run python -m uvicorn app.main:app --host 0.0.0.0 --port 8001 --reload
DATABASE_SERVICE_URL=http://127.0.0.1:8001

# Must match Back_end_database/.env INTERNAL_API_TOKEN if DB token checking is enabled.
# In dev mode DB also works with an empty token if Back_end_database/.env has INTERNAL_API_TOKEN empty.
INTERNAL_API_TOKEN=change-this-token

# Host saved in live_sessions and returned to frontend for Rust session server.
SESSION_HOST=http://127.0.0.1

# Optional. If not set, Authority looks for ../Back_end_session/target/release/Back_end_session(.exe)
# SESSION_BINARY_PATH=C:\full\path\to\Back_end_session.exe
# SESSION_BINARY_PATH=/full/path/to/Back_end_session

SESSION_TTL_SECONDS=3600

# Frontend currently does not send X-API-Token to Authority, so keep false for normal dev.
REQUIRE_EXTERNAL_API_TOKEN=false
